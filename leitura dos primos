Algoritmo "desgraça dos primos"

Var
 a, d, n1, n2, c, s, q, ma, me:inteiro
 m:real

Inicio
escreva("digite os numeros")
leia(n1, n2)
se (n1 < 0) ou (n2 < 0) ou (n1 > n2) entao
escreva("intervalo invalido")
senao
para a de n1 ate n2 passo 1 faca
c <- 0
  para d de 1 ate a faca
  se (a % d = 0) entao
  c <- c + 1
  fimse
  fimpara
  se (c = 2) entao
  escreva(a)
  q <- q + 1
  s <- s + a
  se (q = 1) entao
  me <- a
  ma <- a
  fimse
  se (a > ma) entao
  ma <- a
  fimse
  se (a < me) entao
  me <- a
  fimse
  fimse
  fimpara
se (q <> 0) entao
m <- s / q
escreval("soma =", s)
escreval("quantidade", q)
escreval("media", m)
escreval("o menor =", me)
escreval("o maior", ma)
senao
escreva("ideterminado")
fimse
fimse
Fimalgoritmo
